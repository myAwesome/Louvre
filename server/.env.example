# Required: MySQL DSN — replace with actual credentials
DB_DSN=user:password@tcp(127.0.0.1:3306)/foto-ill?charset=utf8mb4&parseTime=True&loc=Local

# Required: absolute path to the assets/origin directory
ASSETS_DIR=/path/to/foto-ill/public/assets/origin
THUMBS_DIR=/path/to/foto-ill/public/assets/thumbs
# Optional: API key for request authentication (X-API-Key header).
# Leave empty to disable auth (development only).
API_KEY=change-me-to-a-strong-random-value

# Optional: comma-separated list of allowed CORS origins.
# Defaults to http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional: server port. Defaults to 8080
PORT=8080

# Optional: macOS app name for opening files in Photoshop.
# Defaults to "Adobe Photoshop 2025"
PHOTOSHOP_APP=Adobe Photoshop 2025
